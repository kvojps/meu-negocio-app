{
  "name": "meu-negocio-app",
  "version": "0.4.11",
  "private": true,
  "main": "dist/electronApp.js",
  "scripts": {
    "build": "npm run build:renderer && npm run build:main",
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "vite build --config renderer/vite.config.ts",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.11.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.4.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^25.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.1.6",
    "vite": "^5.4.8"
  },
  "build": {
    "appId": "com.meunegocio.app",
    "productName": "Meu Negócio",
    "directories": {
      "output": "release/"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ]
  }
}
