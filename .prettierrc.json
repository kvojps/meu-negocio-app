{
  "semi": true,
  "singleQuote": true,
  "printWidth": 100,
  "plugins": ["@trivago/prettier-plugin-sort-imports"],
  "importOrder": [
    "<THIRD_PARTY_MODULES>",
    "^@shared/(.*)$",
    "^@(/|api/|components/|contexts/|pages/|hooks/|assets/|theme/)(.*)$",
    "^\\.\\.?/.*routes",
    "^\\.\\.?/.*pages",
    "^\\.\\.?/.*components",
    "^\\.\\.?/.*assets",
    "\\.css$",
    "^[.]"
  ],
  "importOrderSeparation": false,
  "importOrderSortSpecifiers": true
}
