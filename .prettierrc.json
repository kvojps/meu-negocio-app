{
  "singleQuote": true,
  "semi": true,
  "plugins": ["@trivago/prettier-plugin-sort-imports"],
  "importOrder": [
    "<THIRD_PARTY_MODULES>",
    "^\\.\\.?/.*routes",
    "^\\.\\.?/.*pages",
    "^\\.\\.?/.*components",
    "^\\.\\.?/.*assets",
    "\\.css$",
    "^[.]"
