{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020", "DOM"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "app/app.ts",
    "app/backend/**/*.ts",
    "app/shared/**/*.d.ts",
    "app/shared/**/*.ts"
  ]
}
